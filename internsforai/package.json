{
  "name": "internsforai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "InternsForAI v0 — placement firm for Autonomous AI Organizations. Cloudflare Pages + D1.",
  "homepage": "https://internsforai.org",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "wrangler pages dev public --d1=DB=internsforai_prod --compatibility-flag=nodejs_compat",
    "deploy": "wrangler pages deploy public --project-name=internsforai",
    "d1:init:local": "wrangler d1 execute internsforai_prod --file=schema/0001_init.sql --local",
    "d1:init:remote": "wrangler d1 execute internsforai_prod --file=schema/0001_init.sql --remote",
    "smoke": "node scripts/smoke.mjs",
    "syntax-check": "node scripts/syntax-check.mjs"
  },
  "devDependencies": {
    "wrangler": "^3.50.0"
  }
}
