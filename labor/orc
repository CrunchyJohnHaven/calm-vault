# very lightweight signal-keyword classifier; precision over recall here
TASK_KEYWORDS: dict[str, list[str]] = {
    "qa_read_through":          ["qa ", "defect", "salted", "line ", "severity"],
    "copy_edit":                ["copy edit", "copy-edit", "tracked changes"],
    "proofread":                ["proofread", "typo"],
    "translate":                ["translat", "back-translation"],
    "transcribe":               ["transcrib", "audio min", "srt"],
    "data_entry":               ["data entry", "csv", "rows"],
    "prospect_research":        ["prospect", "lead", "verified-email"],
    "inbox_triage":             ["inbox triage", "support ticket"],
    "manual_ux_qa":             ["ux qa", "click-through", "screen recording"],
    "bounty_submission_triage": ["bounty", "submission triage", "dedupe"],
    "social_media_management":  ["social media", "scheduling", "reply log"],
}

CHANNEL_KEYWORDS: dict[str, list[str]] = {
    "onlinejobs_ph":  ["onlinejobs", "onlinejobs.ph"],
    "upwork":         ["upwork"],
    "fiverr":         ["fiverr"],
    "freelancer_com": ["freelancer.com"],
    "peopleperhour":  ["peopleperhour", "pph"],
    "reddit_forhire": ["reddit", "r/forhire", "[hiring]"],
    "mechanical_turk":["mturk", "mechanical turk"],
    "clickworker":    ["clickworker"],
    "rev_com":        ["rev.com"],
    "reedsy":         ["reedsy"],
}


def _guess(text: str, table: dict[str, list[str]]) -> str | None:
    t = text.lower()
    best: tuple[int, str] | None = None
    for label, kws in table.items():
        score = sum(1 for kw in kws if kw in t)
        if score and (best is None or score > best[0]):
            best = (score, label)
    return best[1] if best else None


RATE_REGEX = re.compile(
    r"\$\s?(?P<lo>\d{1,3}(?:[.,]\d{1,2})?)\s?(?:-|to|\u2013)\s?\$?\s?"
    r"(?P<hi>\d{1,3}(?:[.,]\d{1,2})?)\s?(?:/?\s?(?:hr|hour))?"
    r"|\$\s?(?P<flat>\d{1,3}(?:[.,]\d{1,2})?)\s?(?:/?\s?(?:hr|hour))",
    re.I,
)


def _extract_rate(text: str) -> str | None:
    m = RATE_REGEX.search(text)
    if not m:
        return None
    if m.group("flat"):
        return f"${m.group('flat')}/hr"
    return f"${m.group('lo')}-${m.group('hi')}/hr"


def _pull_quote(text: str, n: int = 140) -> str:
    snippet = " ".join(text.split())
    return snippet[:n] + ("..." if len(snippet) > n else "")


def _recommend(applicant: dict) -> str:
    body = (applicant.get("body") or applicant.get("raw_text") or "").lower()
    if not body:
        return "maybe"
    # cheap heuristic: explicit pull-quote acknowledgement => shortlist
    if "salted bugs" in body or "fixed-price 48-hour qa test" in body:
        return "shortlist"
    # template/no-signal => reject
    template_markers = [
        "i am the best", "i am very interested", "kindly consider me",
        "please consider", "i can do this job",
    ]
    if any(m in body for m in template_markers) and len(body.split()) < 60:
        return "reject"
    return "maybe"


def cmd_inbox(args: argparse.Namespace) -> int:
    src = Path(args.source).expanduser() if args.source else DEFAULT_INBOX
    if not src.exists():
        print(f"[orc] inbox source not found: {src}", file=sys.stderr)
        print("[orc] expected ~/AllData/inbox/listener.jsonl with rows like:",
              file=sys.stderr)
        print('  {"ts": "...", "channel": "upwork", "from": "...",'
              ' "body": "..."}', file=sys.stderr)
        return 1

    raw = read_jsonl(src)
    if args.since:
        raw = [r for r in raw if r.get("ts", "") >= args.since]

    classified: list[dict] = []
    for r in raw:
        body = r.get("body") or r.get("raw_text") or ""
        channel = r.get("channel") or _guess(body, CHANNEL_KEYWORDS) or "unknown"
        task    = r.get("task_type") or _guess(body, TASK_KEYWORDS) or "unknown"
        rate    = r.get("rate_quoted") or _extract_rate(body)
        name    = r.get("from") or r.get("applicant_name") or "anon"
        record = {
            "ts":                  r.get("ts") or now_iso(),
            "channel":             channel,
            "posting_id":          r.get("posting_id"),
            "applicant_name":      name,
            "applicant_signal":    task,
            "rate_quoted":         rate,
            "sample_pull_quote":   _pull_quote(body),
            "recommended_action":  _recommend({"body": body}),
        }
        classified.append(record)
        if not args.dry_run:
            append_jsonl(APPLICATIONS_LOG, record)

    # surface
    if not classified:
        print("[orc] inbox: 0 new messages")
        return 0

    counts: dict[str, int] = {}
    actions: dict[str, int] = {}
    for r in classified:
        counts[r["channel"]] = counts.get(r["channel"], 0) + 1
        actions[r["recommended_action"]] = \
            actions.get(r["recommended_action"], 0) + 1

    print(f"# orc inbox  -- classified {len(classified)} applicant(s)")
    print(f"# by channel: " +
          ", ".join(f"{k}={v}" for k, v in sorted(counts.items())))
    print(f"# action:     " +
          ", ".join(f"{k}={v}" for k, v in sorted(actions.items())))
    print()
    for r in classified[: args.limit]:
        print(f"- [{r['recommended_action'].upper():9}] "
              f"{r['channel']:14}  {r['applicant_signal']:22}  "
              f"{r['rate_quoted'] or '?':12}  {r['applicant_name']}")
        print(f"  '{r['sample_pull_quote']}'")
    if args.dry_run:
        print("\n[orc] --dry-run: nothing written to applications.jsonl",
              file=sys.stderr)
    return 0


