def _resolve_posting(test_id: str | None, task: str | None, channel: str | None) -> dict | None:
    postings = read_jsonl(POSTINGS_LOG)
    if test_id:
        cands = [p for p in postings if p.get("test_id") == test_id]
        if channel:
            cands = [p for p in cands if p.get("channel") == channel]
        return cands[-1] if cands else None
    if task and channel:
        cands = [p for p in postings
                 if p.get("task_type") == task and p.get("channel") == channel]
        return cands[-1] if cands else None
    return None


def cmd_score(args: argparse.Namespace) -> int:
    posting = _resolve_posting(args.test, args.task, args.channel)
    if not posting:
        if not (args.task and args.channel):
            sys.exit("[orc] could not resolve posting. Pass --test TEST_ID "
                     "or both --task and --channel.")
        # no prior posting: still allow recording (e.g. one-off jobs)
        posting = {
            "posting_id": short_id("post"),
            "task_type":  args.task,
            "channel":    args.channel,
            "test_id":    args.test,
        }
        print(f"[orc] note: no matching posting; recording an ad-hoc work row "
              f"for {args.channel}/{args.task}", file=sys.stderr)

    if args.hours <= 0:
        sys.exit("[orc] --hours must be > 0")
    if not (0 <= args.quality <= 10):
        sys.exit("[orc] --quality must be 0..10")
    if args.paid < 0:
        sys.exit("[orc] --paid must be >= 0")

    row = {
        "ts":              now_iso(),
        "work_id":         short_id("work"),
        "worker_id":       args.worker_id,
        "task_type":       posting["task_type"],
        "channel":         posting["channel"],
        "posting_id":      posting.get("posting_id"),
        "test_id":         posting.get("test_id"),
        "brief_url":       args.brief or None,
        "accepted_at":     args.accepted_at or None,
        "delivered_at":    args.delivered_at or now_iso(),
        "hours_worked":    args.hours,
        "total_paid_usd":  args.paid,
        "quality_score_0_to_10": args.quality,
        "defect_notes":    args.notes or "",
    }
    append_jsonl(WORK_LOG, row)

    eff_rate = (args.paid / args.hours) if args.hours else 0.0
    print(f"# logged work_id={row['work_id']}")
    print(f"# {args.worker_id}  task={row['task_type']}  channel={row['channel']}"
          f"  hrs={args.hours}  $/hr={eff_rate:.2f}  quality={args.quality}/10")
    if args.payment_status:
        append_jsonl(PAYMENTS_LOG, {
            "ts": now_iso(),
            "work_id": row["work_id"],
            "worker_id": args.worker_id,
            "amount_usd": args.paid,
            "status": args.payment_status,
        })
    return 0


