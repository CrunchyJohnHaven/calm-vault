def cmd_dashboard(args: argparse.Namespace) -> int:
    postings = read_jsonl(POSTINGS_LOG)
    apps     = read_jsonl(APPLICATIONS_LOG)
    work     = read_jsonl(WORK_LOG)
    payments = read_jsonl(PAYMENTS_LOG)
    task_types = load_task_types()
    channels_cfg = load_channels()

    md = _render_dashboard(postings, apps, work, payments,
                            task_types, channels_cfg)
    if args.write:
        DASHBOARD_MD.write_text(md, encoding="utf-8")
        print(f"[orc] wrote {DASHBOARD_MD.relative_to(LABOR_DIR.parent)}",
              file=sys.stderr)
    sys.stdout.write(md)
    return 0


def _days_since(ts: str) -> float | None:
    try:
        t = datetime.strptime(ts, "%Y-%m-%dT%H:%M:%SZ").replace(tzinfo=timezone.utc)
    except Exception:
        return None
    return (datetime.now(timezone.utc) - t).total_seconds() / 86400.0


def _render_dashboard(postings, apps, work, payments, task_types, channels):
    now = now_iso()
    active_postings = [p for p in postings
                       if p.get("status") not in ("closed", "filled")]
    apps_by_channel: dict[str, int] = {}
    for a in apps:
        apps_by_channel[a.get("channel", "?")] = \
            apps_by_channel.get(a.get("channel", "?"), 0) + 1

    in_progress_by_task: dict[str, int] = {}
    for p in active_postings:
        in_progress_by_task[p.get("task_type", "?")] = \
            in_progress_by_task.get(p.get("task_type", "?"), 0) + 1

    pending_payments = [pmt for pmt in payments if pmt.get("status") != "paid"]
    burn_week = 0.0
    burn_month = 0.0
    for w in work:
        d = _days_since(w.get("delivered_at") or w.get("ts", ""))
        if d is None:
            continue
        paid = float(w.get("total_paid_usd") or 0)
        if d <= 7:
            burn_week += paid
        if d <= 30:
            burn_month += paid
    projected_month = burn_week * (30 / 7) if burn_week else 0.0

    # current best channel per task type
    best_by_task: dict[str, dict | None] = {}
    for t in task_types:
        best_by_task[t] = leaderboard_mod.recommend(work, t)

    # single "what to do next" line
    next_step = _next_step(active_postings, apps, work, best_by_task)

    out: list[str] = []
    out.append("# John's labor-orchestrator dashboard")
    out.append(f"_generated {now} by `labor/orc dashboard`_\n")

    out.append("## Single recommendation")
    out.append(f"**{next_step}**\n")

    out.append("## Active postings")
    if active_postings:
        out.append("| channel | task_type | budget | status | days "
                   "since posted | posting_id |")
        out.append("|---|---|---|---|---|---|")
        for p in active_postings:
            d = _days_since(p.get("ts", ""))
            d_str = f"{d:.1f}" if d is not None else "?"
            out.append(f"| {p.get('channel')} | {p.get('task_type')} | "
                       f"${float(p.get('budget_usd') or 0):.2f} | "
                       f"{p.get('status')} | {d_str} | "
                       f"`{p.get('posting_id')}` |")
    else:
        out.append("_(none)_")
    out.append("")

    out.append("## Open applications by channel")
    if apps_by_channel:
        out.append("| channel | count |")
        out.append("|---|---|")
        for ch, n in sorted(apps_by_channel.items(),
                            key=lambda kv: -kv[1]):
            out.append(f"| {ch} | {n} |")
    else:
        out.append("_(none — run `orc inbox` once listener.jsonl has rows)_")
    out.append("")

    out.append("## In-progress work by task_type")
    if in_progress_by_task:
        out.append("| task_type | active postings |")
        out.append("|---|---|")
        for t, n in sorted(in_progress_by_task.items(),
                           key=lambda kv: -kv[1]):
            out.append(f"| {t} | {n} |")
    else:
        out.append("_(none)_")
    out.append("")

    out.append("## Pending payments John needs to authorize")
    if pending_payments:
        out.append("| worker | amount | status | work_id |")
        out.append("|---|---|---|---|")
        for pmt in pending_payments:
            out.append(f"| {pmt.get('worker_id')} | "
                       f"${float(pmt.get('amount_usd') or 0):.2f} | "
                       f"{pmt.get('status') or '?'} | "
                       f"`{pmt.get('work_id')}` |")
    else:
        out.append("_(none)_")
    out.append("")

    out.append("## Current best channel per task_type")
    out.append("| task_type | best channel | n | $/hr | quality | $/quality |")
    out.append("|---|---|---|---|---|---|")
    for t in sorted(task_types):
        rec = best_by_task.get(t)
        if rec:
            out.append(f"| {t} | **{rec['channel']}** | {rec['n']} | "
                       f"${rec['mean_cost_per_hr']:.2f} | "
                       f"{rec['mean_quality']:.2f}/10 | "
                       f"${rec['cost_per_quality']:.2f} |")
        else:
            out.append(f"| {t} | _untested_ | 0 | - | - | - |")
    out.append("")

    out.append("## Burn")
    out.append(f"- this week (rolling 7d):   **${burn_week:.2f}**")
    out.append(f"- this month (rolling 30d): **${burn_month:.2f}**")
    out.append(f"- projected month (extrapolated from week 1): "
               f"**${projected_month:.2f}**")
    out.append("")

    out.append("---")
    out.append(f"_state files: "
               f"`labor/state/postings.jsonl` ({len(postings)} rows), "
               f"`applications.jsonl` ({len(apps)}), "
               f"`work.jsonl` ({len(work)}), "
               f"`payments.jsonl` ({len(payments)})_")
    return "\n".join(out) + "\n"


def _next_step(active_postings, apps, work, best_by_task) -> str:
    """Single recommendation line. Rules, in priority order."""
    # 1. unscored deliveries (delivered but no quality recorded) -- score them
    delivered_unscored = [w for w in work
                          if w.get("delivered_at") and
                             w.get("quality_score_0_to_10") in (None, "")]
    if delivered_unscored:
        w = delivered_unscored[0]
        return (f"Score {len(delivered_unscored)} delivered-but-unscored "
                f"work item(s). Start with "
                f"{w.get('worker_id')} ({w.get('channel')}/{w.get('task_type')}).")

    # 2. open applications waiting on John's hire decision
    shortlist = [a for a in apps if a.get("recommended_action") == "shortlist"]
    if shortlist:
        return (f"Review {len(shortlist)} shortlisted applicant(s) and award "
                f"contracts. Start with {shortlist[0].get('applicant_name')}.")

    # 3. mid-test fan-out: a task has 1 channel posted; cast the other 3
    by_task_channels: dict[str, set[str]] = {}
    for p in active_postings:
        by_task_channels.setdefault(p.get("task_type", "?"), set()).add(
            p.get("channel", "?")
        )
    default_4 = ["upwork", "fiverr", "reddit_forhire", "onlinejobs_ph"]
    for t, chs in by_task_channels.items():
        if 1 <= len(chs) < 4:
            missing = [c for c in default_4 if c not in chs]
            if missing:
                return (f"Fan out the {t} test to the remaining "
                        f"channel(s): `orc post --task {t} "
                        f"--channels {','.join(missing)} "
                        f"--budget 25 --per-channel`")

    # 4. tested-but-not-yet-scaled winners
    scaled_ready = [(t, rec) for t, rec in best_by_task.items()
                    if rec and rec.get("n", 0) >= 3]
    if scaled_ready:
        t, rec = scaled_ready[0]
        return (f"Scale winner: post 10x more {t} work to "
                f"{rec['channel']} this week.")

    # 5. tasks with no postings yet -- cast nets
    tested = {p.get("task_type") for p in active_postings}
    tested |= {w.get("task_type") for w in work}
    untested = [t for t in best_by_task if t not in tested]
    if untested:
        return (f"Cast a 4-channel net for an untested task_type. Suggested: "
                f"`orc post --task {untested[0]} --channels "
                f"upwork,fiverr,reddit_forhire,onlinejobs_ph --budget 100`")

    # 6. nothing pending -- monitor
    return "All caught up. Re-check inbox in 12 hr; rerun `orc dashboard`."


# --------------------------------------------------------------------------- #
# argparse plumbing
# --------------------------------------------------------------------------- #


def build_parser() -> argparse.ArgumentParser:
    ap = argparse.ArgumentParser(
        prog="orc",
        description="labor-orchestrator-v2 -- cast nets, measure, scale winners",
    )
    sub = ap.add_subparsers(dest="cmd", required=True)

    p_post = sub.add_parser(
        "post",
        help="emit paste-ready job postings for one task across N channels",
    )
    p_post.add_argument("--task", required=True,
                        help="task_type key from labor/task_types.yaml")
    p_post.add_argument("--channels", required=True,
                        help="comma-separated channel keys from "
                             "labor/channels.yaml")
    p_post.add_argument("--budget", required=True,
                        help="total budget in USD (split evenly) "
                             "or per-channel when --per-channel is set")
    p_post.add_argument("--per-channel", action="store_true",
                        help="treat --budget as per-channel, not total")
    p_post.add_argument("--test-id", default=None,
                        help="re-use a specific test_id (default: auto)")
    p_post.add_argument("--notes", default="",
                        help="freeform note attached to each posting row")
    p_post.set_defaults(func=cmd_post)

    p_inbox = sub.add_parser(
        "inbox",
        help="read listener.jsonl, classify, write to applications.jsonl",
    )
    p_inbox.add_argument("--source", default=None,
                         help=f"path to listener.jsonl (default {DEFAULT_INBOX})")
    p_inbox.add_argument("--since", default=None,
                         help="only consider rows with ts >= this (ISO-8601)")
    p_inbox.add_argument("--limit", type=int, default=20,
                         help="max rows to print (state file always full)")
    p_inbox.add_argument("--dry-run", action="store_true",
                         help="classify and print, but do not append to "
                              "applications.jsonl")
    p_inbox.set_defaults(func=cmd_inbox)

    p_score = sub.add_parser(
        "score",
        help="record a completed work item (the only way to add to work.jsonl)",
    )
    p_score.add_argument("worker_id", help="our handle for the worker")
    p_score.add_argument("--test", default=None,
                         help="test_id from a prior `orc post` (preferred)")
    p_score.add_argument("--task", default=None, help="task_type key")
    p_score.add_argument("--channel", default=None, help="channel key")
    p_score.add_argument("--quality", type=float, required=True,
                         help="0..10 quality score (see task_type's "
                              "quality_metric_definition)")
    p_score.add_argument("--hours", type=float, required=True,
                         help="hours worked (use est. for fixed-price)")
    p_score.add_argument("--paid", type=float, required=True,
                         help="total USD paid for this work item")
    p_score.add_argument("--brief", default=None, help="URL to brief sent")
    p_score.add_argument("--accepted-at", default=None,
                         help="ISO ts when worker accepted")
    p_score.add_argument("--delivered-at", default=None,
                         help="ISO ts when work was delivered (default now)")
    p_score.add_argument("--notes", default="",
                         help="freeform defect/quality notes")
    p_score.add_argument("--payment-status", default=None,
                         choices=[None, "pending", "authorized", "paid"],
                         help="optional payment-state to log alongside")
    p_score.set_defaults(func=cmd_score)

    p_lb = sub.add_parser("leaderboard",
                          help="compute and print the channel x task-type table")
    p_lb.add_argument("--write", action="store_true",
                      help="also write to labor/leaderboard.md")
    p_lb.set_defaults(func=cmd_leaderboard)

    p_rec = sub.add_parser("recommend",
                           help="best channel for a given task_type and why")
    p_rec.add_argument("--task", required=True, help="task_type key")
    p_rec.set_defaults(func=cmd_recommend)

    p_dash = sub.add_parser("dashboard",
                            help="render John's single-page dashboard markdown")
    p_dash.add_argument("--write", action="store_true",
                        help="also write to labor/DASHBOARD.md")
    p_dash.set_defaults(func=cmd_dashboard)

    return ap


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    return args.func(args) or 0


if __name__ == "__main__":
    sys.exit(main())
