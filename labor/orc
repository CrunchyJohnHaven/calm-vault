# --------------------------------------------------------------------------- #
# small helpers
# --------------------------------------------------------------------------- #


def now_iso() -> str:
    return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def short_id(prefix: str) -> str:
    return f"{prefix}_{uuid.uuid4().hex[:8]}"


def ensure_state_dir() -> None:
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    for p in (POSTINGS_LOG, APPLICATIONS_LOG, WORK_LOG, PAYMENTS_LOG):
        if not p.exists():
            p.touch()


def append_jsonl(path: Path, row: dict) -> None:
    ensure_state_dir()
    with path.open("a", encoding="utf-8") as fh:
        fh.write(json.dumps(row, ensure_ascii=False, sort_keys=True) + "\n")


def read_jsonl(path: Path) -> list[dict]:
    if not path.exists():
        return []
    out: list[dict] = []
    with path.open("r", encoding="utf-8") as fh:
        for line in fh:
            line = line.strip()
            if not line:
                continue
            try:
                out.append(json.loads(line))
            except json.JSONDecodeError as exc:
                print(f"[orc] WARN: bad jsonl line in {path}: {exc}",
                      file=sys.stderr)
    return out


def load_yaml(path: Path) -> dict:
    try:
        import yaml  # type: ignore
    except ImportError:
        sys.exit(
            "[orc] PyYAML missing. Run:  pip install -r labor/requirements.txt"
        )
    with path.open("r", encoding="utf-8") as fh:
        data = yaml.safe_load(fh)
    if not isinstance(data, dict):
        sys.exit(f"[orc] expected mapping at top of {path}")
    return data


def load_task_types() -> dict:
    return load_yaml(TASK_TYPES_FILE)


def load_channels() -> dict:
    return load_yaml(CHANNELS_FILE)


def require_known_task(task: str, task_types: dict) -> None:
    if task not in task_types:
        sys.exit(
            f"[orc] unknown task type '{task}'.\n"
            f"      known: {', '.join(sorted(task_types))}"
        )


def require_known_channels(channels: Iterable[str], channels_cfg: dict) -> None:
    unknown = [c for c in channels if c not in channels_cfg]
    if unknown:
        sys.exit(
            f"[orc] unknown channel(s): {', '.join(unknown)}.\n"
            f"      known: {', '.join(sorted(channels_cfg))}"
        )


def posting_template_path(task: str, channel: str) -> Path:
    return POSTINGS_DIR / task / f"{channel}.md"


# --------------------------------------------------------------------------- #
# `orc post`
# --------------------------------------------------------------------------- #


def cmd_post(args: argparse.Namespace) -> int:
    task_types = load_task_types()
    channels_cfg = load_channels()

    require_known_task(args.task, task_types)
    channels = [c.strip() for c in args.channels.split(",") if c.strip()]
    if not channels:
        sys.exit("[orc] --channels is required, comma-separated")
    require_known_channels(channels, channels_cfg)

    if args.per_channel:
        per_channel = float(args.budget)
        total = per_channel * len(channels)
    else:
        total = float(args.budget)
        per_channel = round(total / len(channels), 2)

    test_id = args.test_id or short_id("test")
    print(f"# orc post  task={args.task}  channels={','.join(channels)}")
    print(f"# test_id={test_id}  per_channel=${per_channel:.2f}"
          f"  total=${total:.2f}")
    print()

    missing: list[str] = []
    for ch in channels:
        tpl = posting_template_path(args.task, ch)
        if not tpl.exists():
            missing.append(str(tpl.relative_to(LABOR_DIR)))
            continue
        body = tpl.read_text(encoding="utf-8")
        print(f"========== PASTE INTO {ch.upper()} ==========")
        print(body.rstrip())
        print()

        posting_id = short_id("post")
        append_jsonl(
            POSTINGS_LOG,
            {
                "ts": now_iso(),
                "posting_id": posting_id,
                "test_id": test_id,
                "task_type": args.task,
                "channel": ch,
                "budget_usd": per_channel,
                "status": "drafted",
                "template_path": str(tpl.relative_to(LABOR_DIR.parent)),
                "platform_url": None,
                "notes": args.notes or "",
            },
        )
        print(f"# logged posting_id={posting_id}  channel={ch}"
              f"  budget=${per_channel:.2f}")
        print()

    if missing:
        print("[orc] WARN: missing templates (write them next):",
              file=sys.stderr)
        for m in missing:
            print(f"  - {m}", file=sys.stderr)

    print(f"# test_id={test_id} -- use this when scoring deliveries:"
          f"  orc score <worker_id> --test {test_id} ...")
    return 0


