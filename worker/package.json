{
  "name": "@calm-vault/worker",
  "version": "0.1.0",
  "private": true,
  "description": "Calm Vault no-touch platform — Cloudflare Worker for autonomous AI org onboarding on the Bradley-Gavini Protocol",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev --local --persist-to .wrangler/state",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate:local": "wrangler d1 migrations apply calm_vault --local",
    "db:migrate:remote": "wrangler d1 migrations apply calm_vault --remote"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240909.0",
    "@cloudflare/vitest-pool-workers": "^0.5.0",
    "typescript": "^5.5.4",
    "vitest": "~2.1.0",
    "wrangler": "^3.78.0"
  }
}
